{
  "name": "AI Side Panel",
  "description": "Open a side panel to quickly access ChatGPT or Gemini.",
  "version": "0.1.0",
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "AI Side Panel"
  },
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "*://chat.deepseek.com/*",
    "*://chat.qwen.ai/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "minimum_chrome_version": "116",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the AI side panel"
    }
  }
}
